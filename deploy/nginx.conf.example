# Randnotiz — example host-nginx site (Debian/Ubuntu).
#   Target:  /etc/nginx/sites-available/your-domain.example.com
#   Enable:  ln -s ../sites-available/your-domain.example.com /etc/nginx/sites-enabled/
#
# Replace every "your-domain.example.com" below with your real domain.
# The app sets its own security headers (CSP, X-Frame-Options, X-Content-Type-Options,
# Referrer-Policy) — nginx only adds HSTS on the TLS layer, no duplication.
# Assumes the app container is bound to 127.0.0.1:8300 (see docker-compose.yml).

limit_req_zone $binary_remote_addr zone=bradmin:10m rate=10r/m;

server {
    listen 80;
    listen [::]:80;
    server_name your-domain.example.com;

    # ACME HTTP-01 (certbot renew --webroot)
    location /.well-known/acme-challenge/ {
        root /var/www/certbot;
    }

    location / {
        return 301 https://$host$request_uri;
    }
}

server {
    listen 443 ssl;
    listen [::]:443 ssl;
    http2 on;
    server_name your-domain.example.com;

    ssl_certificate     /etc/letsencrypt/live/your-domain.example.com/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/your-domain.example.com/privkey.pem;
    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_prefer_server_ciphers off;

    add_header Strict-Transport-Security "max-age=31536000" always;
    server_tokens off;

    # Rate-limit the admin login against brute force.
    location /admin {
        limit_req zone=bradmin burst=5 nodelay;
        proxy_pass http://127.0.0.1:8300;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    location / {
        proxy_pass http://127.0.0.1:8300;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }
}
