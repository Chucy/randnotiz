# Randnotiz — Beispiel-Konfiguration. Kopieren nach .env und Werte setzen.
# Randnotiz — example configuration. Copy to .env and fill in the values.
# Die .env selbst gehört NICHT ins Repo (steht in .gitignore).
# The .env file itself must NOT go into the repo (it's in .gitignore).

# Admin-Login-Key. Lang und zufällig wählen, z. B.:  openssl rand -hex 32
# Admin login key. Choose long and random, e.g.:      openssl rand -hex 32
RANDNOTIZ_ADMIN_KEY=

# Verzeichnis mit einem Ordner pro Buch (<slug>/ mit Kapiteln, Makefile, assets/).
# Im Container per Volume gemountet; für lokalen Betrieb ein absoluter Pfad.
# Directory with one folder per book (<slug>/ with chapters, Makefile, assets/).
# Mounted into the container via a volume; use an absolute path for local runs.
RANDNOTIZ_BOOKS=/srv/buecher

# SQLite-Pfad. Default reicht meist (data/randnotiz.db). Nie auf NFS/CIFS legen.
# SQLite path. The default is usually fine (data/randnotiz.db). Never on NFS/CIFS.
# RANDNOTIZ_DB=/srv/data/randnotiz.db
