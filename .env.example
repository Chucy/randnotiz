# randnotiz — Beispiel-Konfiguration. Kopieren nach .env und Werte setzen.
# .env selbst gehört NICHT ins Repo (steht in .gitignore).

# Admin-Login-Key. Lang und zufällig wählen, z.B.:  openssl rand -hex 32
RANDNOTIZ_ADMIN_KEY=

# Verzeichnis mit einem Ordner pro Buch (<slug>/ mit Kapiteln, Makefile, assets/).
# Im Container per Volume gemountet; für lokalen Betrieb ein absoluter Pfad.
RANDNOTIZ_BOOKS=/srv/buecher

# SQLite-Pfad. Default reicht meist (data/randnotiz.db). Nie auf NFS/CIFS legen.
# RANDNOTIZ_DB=/srv/data/randnotiz.db
